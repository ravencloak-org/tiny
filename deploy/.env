# NOTE: Dokploy's stored env (panel/DB) is the SOURCE OF TRUTH for prod — it
# rewrites this file from the panel value on every deploy. So editing tags here
# alone does NOT change prod; change them in the Dokploy panel.
#
# Prod deploy model (chosen 2026-06-30): tags pinned to `latest`. release.yml
# builds ghcr :version + :latest on each tag, then POSTs DOKPLOY_DEPLOY_WEBHOOK;
# compose has pull_policy: always, so the redeploy pulls the new :latest digest
# and recreates. These values mirror the panel for local `docker compose` use.
TINYRAVEN_TAG=latest
SITE_TAG=latest
