# Image tags the prod compose pins to. Bump these per release (part of the
# release commit, alongside Chart.yaml/CHANGELOG) so each deploy pulls a DISTINCT
# tag — Dokploy then reliably recreates the container (a static :latest was
# skipped). Do NOT also set TINYRAVEN_TAG/SITE_TAG in the Dokploy UI env, or it
# overrides this file.
TINYRAVEN_TAG=v0.3.0
SITE_TAG=v0.3.0
