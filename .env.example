# TinyRaven runtime config (set these in Dokploy → Environment).
# The tr container is stateless; point it at your ClickHouse + Redis.

TR_HTTP_ADDR=:8000

# ClickHouse (external — Dokploy service, managed CH, or a sibling container)
TR_CLICKHOUSE_HTTP=http://clickhouse:8123
TR_CLICKHOUSE_NATIVE=clickhouse:9000
TR_CLICKHOUSE_DB=tr_main
TR_CLICKHOUSE_USER=default
TR_CLICKHOUSE_PASSWORD=

# Redis (external — metadata registry + cache, AOF-persisted)
TR_REDIS_ADDR=redis:6379

# Project files (.datasource/.pipe) baked into the image or mounted
TR_PROJECT_DIR=/project

# Bootstrap ADMIN token — CHANGE THIS, keep it secret
TR_ADMIN_TOKEN=change-me
